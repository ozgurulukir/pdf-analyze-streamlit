# PDF Analyzer Pro - Environment Variables Template
# Copy this file to .env and fill in your values

# ===================
# Application Settings
# ===================
APP_NAME=PDF Analyzer Pro
APP_ENV=development  # development, production
DEBUG=true

# ===================
# LLM Configuration
# ===================
# Ollama (default local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=""  # or your API key
LLM_MODEL=llama3.2:latest

# OpenAI (alternative)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# LLM Defaults
DEFAULT_LLM_PROVIDER=ollama  # ollama, openai
LLM_TEMPERATURE=0.3

# ===================
# Embedding Configuration
# ===================
# Use HuggingFace embeddings (true) or Ollama (false)
USE_HUGGINGFACE=false
HF_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# ===================
# Data & Storage
# ===================
DATA_DIR=./data
CHROMA_PERSIST_DIR=./data/chroma_db

# ===================
# Chunking Settings
# ===================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ===================
# UI Settings
# ===================
SIDEBAR_DEFAULT_OPEN=true
DEFAULT_PAGE=Chat

# ===================
# Security (Optional)
# ===================
# Rate limiting (requests per minute)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_RPM=60
