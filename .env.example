# ==================== LLM AYARLARI ====================

# OpenAI-compatible endpoint (Ollama Cloud, vLLM, Groq, Together vs.)
LLM_BASE_URL=https://ollama.com/v1

# API Key - Ollama için genellikle "ollama" yeterli
# Diğer servisler için gerçek API key'inizi girin
LLM_API_KEY=ollama

# Model - Ollama Cloud'daki modeller
LLM_MODEL=deepseek-v2:671b

# ==================== EMBEDDING AYARLARI ====================

# Ollama yerel sunucu
OLLAMA_BASE_URL=http://localhost:11434

# Ollama embedding modeli
EMBED_MODEL=nomic-embed-text

# Alternatif: HuggingFace kullanmak için "true" yapın
USE_HUGGINGFACE_EMBED=false
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ==================== VERİ AYARLARI ====================

# Belgelerin bulunduğu klasör
DATA_DIR=./data

# Vector store klasörü
CHROMA_PATH=./chroma_db

# Collection adı
COLLECTION_NAME=rag_collection

# Chunk ayarları
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
